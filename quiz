import pygame
import subprocess
import os
import sys

pygame.font.init()
quiz_font = pygame.font.Font("CaveatBrush-Regular.ttf", 80)

pygame.init()
screen = pygame.display.set_mode((1000, 600))
clock = pygame.time.Clock()
pygame.display.set_caption("Welcome to Fraction Pizzeria ")
done = False

bg_clr = (151, 65, 31)
text_clr = (236, 215, 175)



#Colors
beige = (236, 215, 175)
orange = (216, 104, 40)

class Button:

    def __init__(self, x, y, width, height, text, action=None):
        # Create the core rectangle boundary for collision
        self.rect = pygame.Rect(x, y, width, height)
        self.text = text
        self.action = action
        
        # Set up fonts and render text surface
        self.font = pygame.font.Font("CaveatBrush-Regular.ttf", 30) #MAY NOT WORK
        self.text_surf = self.font.render(self.text, True, orange)
        # Center the text within the rectangle box
        self.text_rect = self.text_surf.get_rect(center=self.rect.center)
    
        # Dynamic color tracking
        self.current_color = beige        
#TITLE
quiz_title_surface = quiz_font.render("---Advanced fraction quiz!---", True, text_clr)
quiz_title_rect = quiz_title_surface.get_rect()

# Position the title
quiz_title_rect.centerx = screen.get_rect().centerx  # Center it 
quiz_title_rect.top = 50

#Question
question_surface = quiz_font.render ("Simplify: 24/50", True, text_clr)
question_rect = question_surface.get_rect()

# Position the question
question_rect.centerx = screen.get_rect().centerx  # Center it 
question_rect.top = 150


while not done:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            done = True
    screen.fill(bg_clr)

    # title text
    screen.blit(quiz_title_surface, quiz_title_rect)    
    
    #Question 
    screen.blit(question_surface, question_rect)    
  

    clock.tick(60) 
    pygame.display.flip()

pygame.quit()
sys.exit()
